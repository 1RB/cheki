{
    "name": "cheki/cheki",
    "version": "1.4.0",
    "description": "PHP SDK for cheki, a free Ethiopian receipt verification service. 10 live banks: CBE, Telebirr, BOA, M-Pesa, Dashen, Awash, Zemen, CBE Birr, Siinqee, eBirr.",
    "type": "library",
    "homepage": "https://chekiapp.vercel.app",
    "license": "MIT",
    "keywords": [
        "cheki",
        "ethiopia",
        "receipt",
        "verification",
        "banking",
        "payment",
        "sdk",
        "cbe",
        "telebirr",
        "m-pesa",
        "dashen",
        "awash",
        "zemen",
        "eBirr"
    ],
    "authors": [
        {
            "name": "1RB",
            "homepage": "https://chekiapp.vercel.app"
        }
    ],
    "support": {
        "issues": "https://github.com/1RB/cheki/issues",
        "source": "https://github.com/1RB/cheki"
    },
    "require": {
        "php": ">=8.0",
        "ext-json": "*",
        "ext-curl": "*"
    },
    "autoload": {
        "psr-4": {
            "Cheki\\": "src/"
        }
    },
    "minimum-stability": "stable"
}
