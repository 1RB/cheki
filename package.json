{
  "name": "cheki",
  "version": "1.4.0",
  "description": "Verify Ethiopian bank payment receipts. Free, open source, no API key. 10 live banks including CBE, Telebirr, BOA, M-Pesa, Dashen, Awash, Zemen, CBE Birr, Siinqee, and eBirr (Nib, Wegagen, Ahadu, KAAFI).",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1RB/cheki.git"
  },
  "bugs": {
    "url": "https://github.com/1RB/cheki/issues"
  },
  "homepage": "https://chekiapp.vercel.app",
  "scripts": {
    "prebuild": "node scripts/download-tesseract-data.js",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "cli": "tsx src/cli/index.ts"
  },
  "bin": {
    "cheki": "src/cli/index.ts"
  },
  "dependencies": {
    "@fontsource/inter": "^5.0.8",
    "@hugeicons/core-free-icons": "^4.2.1",
    "@hugeicons/react": "^1.1.7",
    "cheerio": "^1.0.0",
    "clsx": "^2.1.1",
    "jsqr": "^1.4.0",
    "lucide-react": "^1.21.0",
    "motion": "^12.41.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "pdf-parse": "^1.1.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.34.5",
    "shiki": "^4.2.0",
    "tailwind-merge": "^3.6.0",
    "tesseract.js": "^7.0.0",
    "unpdf": "^1.6.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
